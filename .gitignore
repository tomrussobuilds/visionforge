# =========================================================================== #
#                                PYTHON & ENV
# =========================================================================== #
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
env/
.ipynb_checkpoints/

# =========================================================================== #
#                                IDE & SYSTEM
# =========================================================================== #
.vscode/
.idea/
.DS_Store
Thumbs.db
*.bak
*~
*.swp

# =========================================================================== #
#                            PROJECT ARTIFACTS
# =========================================================================== #
# Experiment outputs and datasets (Managed by RunPaths)
outputs/
dataset/
data/
logs/

# Root-level temporary files
*.log
*.npz
*.pth
*.pt
*.ckpt
*.lock

# =========================================================================== #
#                          ML SPECIFIC (MONITORING)
# =========================================================================== #
wandb/
runs/
.comet_ml/

# =========================================================================== #
#                       LEGACY & UTILITY FOLDERS
# =========================================================================== #
# Ignore the entire legacy folder to keep the repo clean
legacy/

# Track the tools/ folder scripts but ignore their local outputs
!tools/
tools/
tools/__pycache__/
tools/*.log

# =========================================================================== #
#                       DOCUMENTATION & RESULTS
# =========================================================================== #
# If you want to keep specific summary reports, place them in a 'results/' 
# folder and uncomment the line below. Otherwise, keep it ignored.
# !results/